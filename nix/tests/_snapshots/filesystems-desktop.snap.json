{
  "/": {
    "device": "/dev/disk/by-partlabel/disk-main-root",
    "fsType": "btrfs",
    "options": [
      "x-initrd.mount",
      "compress=zstd",
      "noatime",
      "subvol=@"
    ]
  },
  "/.swapvol": {
    "device": "/dev/disk/by-partlabel/disk-main-root",
    "fsType": "btrfs",
    "options": [
      "defaults",
      "subvol=@swap"
    ]
  },
  "/boot": {
    "device": "/dev/disk/by-partlabel/disk-main-ESP",
    "fsType": "vfat",
    "options": [
      "defaults"
    ]
  },
  "/home": {
    "device": "/dev/disk/by-partlabel/disk-main-root",
    "fsType": "btrfs",
    "options": [
      "compress=zstd",
      "noatime",
      "subvol=@home"
    ]
  },
  "/nix": {
    "device": "/dev/disk/by-partlabel/disk-main-root",
    "fsType": "btrfs",
    "options": [
      "x-initrd.mount",
      "compress=zstd",
      "noatime",
      "subvol=@nix"
    ]
  },
  "/run/media/lpchaim/storage": {
    "device": "/dev/disk/by-id/ata-ADATA_SU630_2J0220042661-part1",
    "fsType": "btrfs",
    "options": [
      "defaults",
      "auto",
      "exec",
      "nofail",
      "nosuid",
      "nodev",
      "noatime",
      "compress=zstd",
      "x-gvfs-show"
    ]
  },
  "/var/cache": {
    "device": "/dev/disk/by-partlabel/disk-main-root",
    "fsType": "btrfs",
    "options": [
      "compress=zstd",
      "noatime",
      "nofail",
      "subvol=@cache"
    ]
  },
  "/var/log": {
    "device": "/dev/disk/by-partlabel/disk-main-root",
    "fsType": "btrfs",
    "options": [
      "x-initrd.mount",
      "compress=zstd",
      "noatime",
      "nofail",
      "subvol=@log"
    ]
  }
}